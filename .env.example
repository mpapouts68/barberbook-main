# Copy to .env and fill in values (never commit .env)

# Optional: public contact badges (client build — configure in Admin or here)
# VITE_CONTACT_INSTAGRAM=https://www.instagram.com/your_shop
# VITE_CONTACT_FACEBOOK=https://www.facebook.com/your_shop
# VITE_CONTACT_EMAIL=hello@your-shop.com
# VITE_CONTACT_PHONES=+301234567890
# VITE_CONTACT_ADDRESS=Your address

DATABASE_URL=file:./database.sqlite
# On read-only PaaS hosts (e.g. Hostman App Platform), leave DATABASE_URL as above;
# startup auto-falls back to /tmp/barberbook/database.sqlite if ./ is not writable.
# Optional override for a mounted volume or VPS data dir:
# DATA_DIR=/var/lib/barberbook

BASE_URL=http://localhost:5100
PORT=5100
NODE_ENV=development
SESSION_SECRET=change-me-to-a-long-random-string

# Email (development — use App Password for Gmail SMTP, or Gmail API in production)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="BarberBook <your@gmail.com>"

{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "build": "cross-env NODE_ENV=production vite build && cross-env NODE_ENV=production esbuild server/index.ts --platform=node --packages=external --external:vite --external:@vitejs/plugin-react --external:vite-plugin-pwa --external:./server/vite --external:./vite --bundle --format=esm --outdir=dist --define:process.env.NODE_ENV=\\\"production\\\"",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "db:push": "drizzle-kit push",
    "db:push:force": "drizzle-kit push --force",
    "import-namedays": "tsx server/scripts/import-namedays.ts",
    "import-namedays:force": "tsx server/scripts/import-namedays.ts --force",
    "seed": "cross-env DATABASE_URL=file:./database.sqlite tsx server/seed.ts",
    "check-db": "cross-env DATABASE_URL=file:./database.sqlite tsx server/check-db.ts",
    "verify-db": "cross-env DATABASE_URL=file:./database.sqlite tsx server/verify-db-schema.ts",
    "rebuild-db": "cross-env DATABASE_URL=file:./database.sqlite node scripts/rebuild-database-drizzle.js",
    "fix-schema": "cross-env DATABASE_URL=file:./database.sqlite node fix-missing-schema-safe.js",
    "migrate-reminders": "cross-env DATABASE_URL=file:./database.sqlite node migrate-add-reminder-flags-safe.js",
    "migrate:services-i18n": "cross-env DATABASE_URL=file:./database.sqlite node migrate-services-bilingual-safe.js",
    "migrate:production": "npm run fix-schema && npm run migrate-reminders && npm run migrate:services-i18n",
    "import-backup": "node scripts/import-from-backup.js",
    "generate-icons": "tsx scripts/generate-icons.js",
    "generate-icons:ps1": "powershell -ExecutionPolicy Bypass -File scripts/generate-icons.ps1",
    "test-pwa": "tsx scripts/test-pwa.js",
    "test-email": "tsx scripts/test-email.ts",
    "test-email:server": "node scripts/test-email.cjs",
    "deploy-safe": "powershell -ExecutionPolicy Bypass -File SAFE-DEPLOY-UPDATE.ps1"
  },

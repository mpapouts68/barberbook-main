# Production .env on VPS — copy to /var/www/peqi/.env

NODE_ENV=production
PORT=5100
BASE_URL=https://peqi.hair

# Generate: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_LONG_RANDOM

DATABASE_URL=file:./database.sqlite

# Email — on Hostman VPS SMTP (587) is usually blocked; use Gmail API:
# See deploy/GMAIL-API-SETUP.md
EMAIL_USE_GMAIL_API=true
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token
EMAIL_FROM="PEQI Haircut Studio <peqihaircutstudio@gmail.com>"
EMAIL_USER=peqihaircutstudio@gmail.com

# Local dev / fallback SMTP (optional)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_PASS=YOUR_APP_PASSWORD

# Google Calendar JSON (optional) — or configure in Admin UI
